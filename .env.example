```env
# ==========================================
# Turtle Soup - Environment Variables
# 海龟汤多人游戏环境变量示例
# ==========================================

# 服务端口
PORT=3000

# SQLite 数据库路径
# Docker 中建议使用 /app/data/turtle.db，并把 /app/data 挂载为 volume
DATABASE_PATH=./data/turtle.db

# 允许跨域访问的源。留空表示只允许同源；多个域名用英文逗号分隔。
# 如确实需要全开放，可设为 *，公网不建议。
CORS_ORIGIN=

# ------------------------------------------
# LiveKit 语音配置
# ------------------------------------------

# 服务端连接 LiveKit 的地址
# 本地开发：
LIVEKIT_URL=ws://localhost:7880

# 浏览器连接 LiveKit 的公网地址
# 本地开发可留空
# 部署到服务器后务必修改
# 示例：
# PUBLIC_LIVEKIT_URL=wss://voice.example.com
# 或：
# PUBLIC_LIVEKIT_URL=ws://你的服务器IP:7880
PUBLIC_LIVEKIT_URL=

# LiveKit API Key / Secret
# 必须与 livekit.yaml 或 Docker 配置一致
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# ------------------------------------------
# 车队密码
# ------------------------------------------

# 主持人密码
HOST_PASSWORD=change-host-password

# 玩家密码
PLAYER_PASSWORD=change-player-password

# 管理员密码
ADMIN_PASSWORD=change-admin-password

# ------------------------------------------
# 断线保留时间（毫秒）
# ------------------------------------------

# 玩家断线后，保留在线状态的时间
# 用于刷新页面、网络波动自动恢复
DISCONNECT_GRACE_MS=12000

# 主持人/管理员离开后，房间自动归档并释放房间号的时间（毫秒）
EMPTY_ROOM_TTL_MS=43200000

# 不自动归档的测试/演示房间号，多个用英文逗号分隔
TEST_ROOM_CODES=TS2048

# 登录密码失败限制
FLEET_RATE_WINDOW_MS=60000
FLEET_RATE_MAX_FAILURES=5
```
