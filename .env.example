# ==========================================
# Turtle Soup - Environment Variables
# 海龟汤多人游戏环境变量示例
# ==========================================

# 服务端口
PORT=3000

# SQLite 数据库路径
# Docker 中建议使用 /app/data/turtle.db，并把 /app/data 挂载为 volume
DATABASE_PATH=./data/turtle.db

# 允许跨域访问的源。留空表示只允许同源；多个域名用英文逗号分隔。
# 如确实需要全开放，可设为 *，公网不建议。
CORS_ORIGIN=

# ------------------------------------------
# LiveKit 语音配置
# ------------------------------------------

# 服务端连接 LiveKit 的地址。Docker 部署保持这个值。
LIVEKIT_URL=ws://livekit:7880

# 浏览器连接 LiveKit 的公网地址。
# 如果 voice 域名经反向代理提供 HTTPS/WSS：
PUBLIC_LIVEKIT_URL=wss://voice.example.com
# 如果不用反向代理、直接暴露 LiveKit 7880：
# PUBLIC_LIVEKIT_URL=ws://你的服务器IP:7880

# LiveKit API Key / Secret。公网部署必须修改，app 和 livekit 会共用这组值。
LIVEKIT_API_KEY=change-livekit-key
LIVEKIT_API_SECRET=change-livekit-secret

# TURN 用于解决部分电脑或网络能进房但无法上行/下行语音的问题。
# 建议公网部署启用，并在防火墙/安全组放行对应端口。
LIVEKIT_TURN_ENABLED=false
LIVEKIT_TURN_DOMAIN=voice.example.com
LIVEKIT_TURN_UDP_PORT=3478
LIVEKIT_TURN_TLS_PORT=5349
# 如果 TURN TLS 在 Nginx/Caddy/Cloudflare Spectrum 等外部代理终止 TLS，设为 true。
# 直接由 LiveKit 处理 TLS 时保持 false，并按 LiveKit 官方方式配置证书。
LIVEKIT_TURN_EXTERNAL_TLS=false

# ------------------------------------------
# AI 测试/生成配置
# ------------------------------------------

# 兼容 OpenAI Chat Completions 的接口地址，例如：
# https://api.openai.com/v1/chat/completions
AI_API_URL=
AI_API_KEY=
AI_MODEL=

# ------------------------------------------
# 车队密码
# ------------------------------------------

HOST_PASSWORD=change-host-password
PLAYER_PASSWORD=change-player-password
ADMIN_PASSWORD=change-admin-password

# ------------------------------------------
# 断线保留时间（毫秒）
# ------------------------------------------

# 玩家断线后，保留在线状态的时间。用于刷新页面、网络波动自动恢复。
DISCONNECT_GRACE_MS=12000

# 主持人/管理员离开后，房间自动归档并释放房间号的时间（毫秒）。
EMPTY_ROOM_TTL_MS=43200000

# 不自动归档的测试/演示房间号，多个用英文逗号分隔。
TEST_ROOM_CODES=TS2048

# 登录密码失败限制。
FLEET_RATE_WINDOW_MS=60000
FLEET_RATE_MAX_FAILURES=5
